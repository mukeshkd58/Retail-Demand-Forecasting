# Copy this file to .env and fill in your values
# cp .env.example .env

# ── App settings ───────────────────────────────────────────────────────────────
APP_ENV=development           # development | production
LOG_LEVEL=INFO

# ── Paths (relative to project root) ──────────────────────────────────────────
DATA_DIR=data/raw
MODEL_DIR=models
OUTPUT_DIR=outputs

# ── Flask API ──────────────────────────────────────────────────────────────────
FLASK_HOST=0.0.0.0
FLASK_PORT=5000
FLASK_DEBUG=0

# ── Streamlit ──────────────────────────────────────────────────────────────────
STREAMLIT_PORT=8501

# ── Model training ─────────────────────────────────────────────────────────────
TEST_WEEKS=26
SERVICE_LEVEL=0.95            # inventory service level (0.90 | 0.95 | 0.99)
